# Supabase (optional - configure for auth & database)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# API base URL for lead capture and other endpoints
# Use /api to proxy to Supabase Edge Functions (requires VITE_SUPABASE_URL)
# Or set to https://<project>.supabase.co/functions/v1 for direct Edge Function calls
VITE_API_URL=/api
